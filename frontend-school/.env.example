# Public environment variables (accessible in browser)
# Must be prefixed with PUBLIC_

# Backend API URL - backend-school service
# Production: https://school-api.schoolorbit.app
# Development: http://localhost:8081
PUBLIC_BACKEND_URL=https://school-api.schoolorbit.app

# Optional tenant override for localhost or non-schoolorbit.app hosts
# Production tenant URLs auto-detect this from the hostname.
# PUBLIC_SCHOOL_SUBDOMAIN=demo

# Web Push Notification VAPID Public Key
# Generate using: npx web-push generate-vapid-keys
PUBLIC_VAPID_KEY=BMx...put-your-valid-public-key-here...

# Auto-Register Menu System
# Must match DEPLOY_KEY in backend
VITE_DEPLOY_KEY=local-dev-key-change-me-in-production

# Tenant subdomain used during production build route registration.
# Local dev can omit this; registration is skipped when SUBDOMAIN is absent.
SUBDOMAIN=demo
