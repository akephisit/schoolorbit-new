# PostgreSQL 18 Self-Hosted Database + Backup Configuration
DATABASE_URL=postgresql://schoolorbit_admin_app:password@postgres:5432/schoolorbit_admin?sslmode=disable
SELF_HOSTED_POSTGRES_ADMIN_URL=postgresql://schoolorbit_provisioner:password@postgres:5432/postgres?sslmode=disable
SELF_HOSTED_POSTGRES_APP_HOST=postgres
SELF_HOSTED_POSTGRES_APP_PORT=5432
SELF_HOSTED_POSTGRES_TENANT_USER=schoolorbit_tenant_owner
SELF_HOSTED_POSTGRES_TENANT_PASSWORD=change-this-tenant-password
SELF_HOSTED_POSTGRES_SSLMODE=disable
BACKUP_ROOT=/opt/schoolorbit/backups
BACKUP_RETENTION_DAYS=14
BACKUP_RCLONE_REMOTE=

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=8080
RUST_LOG=info
# Note: CORS is handled by nginx reverse proxy

# Cloudflare Configuration
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_ACCOUNT_ID=your-account-id
BASE_DOMAIN=schoolorbit.app

# Backend-School Communication
BACKEND_SCHOOL_URL=http://backend-school:8081
INTERNAL_API_SECRET=your-internal-secret-change-this-in-production

# Deployment
API_URL=https://school-api.schoolorbit.app

# GitHub Actions Deployment
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_REPO=akephisit/schoolorbit-new
# Optional but recommended: kept in sync with GITHUB_REPO for workflow polling paths
GITHUB_REPOSITORY=akephisit/schoolorbit-new
