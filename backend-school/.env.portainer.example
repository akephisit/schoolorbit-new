# ============================================
# Backend-School Environment Variables
# สำหรับ Portainer Stack
# ============================================

# 1. Backend-admin URL (REQUIRED!)
# backend-school no longer connects to the admin DB directly.
BACKEND_ADMIN_URL=http://schoolorbit-backend-admin:8080

# 2. Internal API Secret (REQUIRED!)
# ต้องตรงกับค่าใน backend-admin
INTERNAL_API_SECRET=your-internal-api-secret-change-this

# 3. JWT Secret (REQUIRED!)
# สำหรับ sign และ verify JWT tokens
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# 4. Server Configuration (Optional - มี default)
RUST_LOG=info
HOST=0.0.0.0
PORT=8081

# 5. Auto-register menu deploy key
# ต้องตรงกับ VITE_DEPLOY_KEY ใน frontend-school build
DEPLOY_KEY=local-dev-key-change-me-in-production

# 6. Data Encryption Key (AES-GCM app-side)
ENCRYPTION_KEY=your-encryption-key-change-me-32-chars-minimum

# 7. Cloudflare R2 / S3-compatible storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=schoolorbit-files
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
R2_REGION=auto
CDN_URL=

# 8. File upload limits and allowed extensions
MAX_FILE_SIZE_MB=10
MAX_PROFILE_IMAGE_SIZE_MB=5
MAX_DOCUMENT_SIZE_MB=20
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp,gif
ALLOWED_DOCUMENT_TYPES=pdf,doc,docx,xls,xlsx

# 9. Web Push Notifications
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@schoolorbit.app

# ============================================
# ⚠️ สิ่งที่ไม่ต้องตั้งอีกต่อไป:
# ============================================
# Tenant database URLs are resolved through backend-admin.
# backend-school does not need DATABASE_URL or Neon credentials.
# backend-admin stores PostgreSQL 18 self-host tenant URLs in schools.db_connection_string.
# ADMIN_DATABASE_URL - ไม่ต้องใช้แล้ว (ใช้ BACKEND_ADMIN_URL แทน)
# ALLOWED_ORIGINS - ไม่ต้องใช้ใน backend-school; CORS จัดการที่ reverse proxy

# ============================================
# 📝 วิธีใช้ใน Portainer:
# ============================================
# 1. ไปที่ Stacks → เลือก backend-school stack
# 2. คลิก "Editor"
# 3. เลื่อนลงไปที่ "Environment variables"
# 4. วาง environment variables ข้างบนนี้
# 5. แก้ไขค่าจริง (BACKEND_ADMIN_URL, secrets, R2, VAPID)
# 6. คลิก "Update the stack"
